# whisper_dictate - Environment Configuration
# =============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
#   cp .env.example .env

# ------------------------------------------------------------------
# Required
# ------------------------------------------------------------------

# Your OpenAI API key. Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_actual_openai_api_key_here

# ------------------------------------------------------------------
# Transcription (optional)
# ------------------------------------------------------------------

# Backend to use for transcription. Currently only 'openai' is supported.
# Future backends (e.g. 'faster-whisper', 'whisper-cpp') will be added here.
TRANSCRIPTION_BACKEND=openai

# Whisper model to use. 'whisper-1' is the only OpenAI API option.
WHISPER_MODEL=whisper-1

# Default language for transcription.
# Use ISO 639-1 codes: 'en', 'es', 'fr', 'de', 'pt', etc.
# Set to 'auto' to let Whisper detect the language automatically.
DEFAULT_LANGUAGE=auto

# Set to 'true' to always translate audio to English.
ENABLE_TRANSLATION=false

# ------------------------------------------------------------------
# Audio (optional)
# ------------------------------------------------------------------

# Microphone sample rate in Hz. 16000 is optimal for Whisper.
SAMPLE_RATE=16000

# Audio capture chunk size in frames.
CHUNK_SIZE=1024

# ------------------------------------------------------------------
# UI / Alerts (optional)
# ------------------------------------------------------------------

# Volume for audio alerts (0.0 = silent, 1.0 = full volume).
ALERT_VOLUME=0.8

# Set to 'false' to disable all audio alerts.
ALERTS_ENABLED=true
